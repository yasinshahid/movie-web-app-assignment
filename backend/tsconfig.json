{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "CommonJS",
		"moduleResolution": "Node",
		"rootDir": ".",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": ["node"],
		"sourceMap": true
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
